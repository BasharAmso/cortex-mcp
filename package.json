{
  "name": "cortex-mcp-server",
  "version": "0.4.2",
  "description": "Framework-agnostic MCP server that serves structured knowledge on-demand to any MCP-compatible AI tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cortex-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build-index": "tsx scripts/build-index.ts",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run build-index && npm run test"
  },
  "keywords": [
    "mcp",
    "knowledge",
    "ai",
    "fragments",
    "context",
    "claude",
    "cursor",
    "windsurf"
  ],
  "author": "Bashar Amso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BasharAmso/cortex-mcp.git"
  },
  "homepage": "https://github.com/BasharAmso/cortex-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "fuse.js": "^7.0.0",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "chokidar": "^4.0.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "resources",
    ".cortex",
    "scripts"
  ]
}
